{
  "name": "TOPAS",
  "scopeName": "text.topas",
  "fileTypes": [],
  "uuid": "65752c66-cd2c-4af4-8afd-c4803161a801",
  "patterns": [
    { "include": "#section_comment" },
    { "include": "#line_comment" },
    { "include": "#include_file" },
    { "include": "#declaration" },
    { "include": "#comment_block" }
  ],
  "repository": {

    "section_comment": {
      "name": "markup.heading.topas",
      "match": "^#\\s*[=\\-]{4,}.*$"
    },

    "line_comment": {
      "name": "comment.line.number-sign.topas",
      "match": "#.*$"
    },

    "comment_block": {
      "name": "comment.block.topas",
      "match": "^(?!.*=).*$"
    },

    "include_file": {
      "name": "meta.include.topas",
      "match": "^\\s*(?i:(includeFile))\\s*(=)\\s*(.+)$",
      "captures": {
        "1": { "name": "keyword.control.import.topas" },
        "2": { "name": "keyword.operator.assignment.topas" },
        "3": { "name": "string.unquoted.path.topas" }
      }
    },

    "declaration": {
      "name": "meta.declaration.topas",
      "match": "^\\s*([bidus]v?c?):((?:(?:Ma|El|Is|Ge|Gr|Ph|So|Sc|Tf|Ts|Vr|Rt)[/\\w]*/)(?:[\\w]+))\\s*(=)\\s*(.*)$",
      "captures": {
        "1": { "name": "storage.type.topas", "patterns": [{ "include": "#data_type_colors" }] },
        "2": { "name": "meta.path.topas", "patterns": [{ "include": "#path_parts" }] },
        "3": { "name": "keyword.operator.assignment.topas" },
        "4": { "name": "meta.value.topas", "patterns": [{ "include": "#value" }] }
      }
    },

    "data_type_colors": {
      "patterns": [
        { "match": "^d", "name": "storage.type.double.topas" },
        { "match": "^u", "name": "storage.type.unitless.topas" },
        { "match": "^i", "name": "storage.type.integer.topas" },
        { "match": "^b", "name": "storage.type.boolean.topas" },
        { "match": "^s", "name": "storage.type.string.topas" }
      ]
    },

    "path_parts": {
      "patterns": [
        {
          "match": "(?i:(Ma|El|Is|Ge|Gr|Ph|So|Sc|Tf|Ts|Vr|Rt))(/[\\w/]*/)?([\\w]+)?",
          "captures": {
            "1": { "name": "entity.name.namespace.topas" },
            "2": { "name": "entity.name.section.topas" },
            "3": { "name": "entity.other.attribute-name.topas" }
          }
        }
      ]
    },

    "value": {
      "patterns": [
        { "include": "#boolean_value" },
        { "include": "#string_value" },
        { "include": "#unit" },
        { "include": "#numeric" },
        { "include": "#operator" },
        { "include": "#parameter_ref" },
        { "include": "#line_comment" }
      ]
    },

    "boolean_value": {
      "name": "constant.language.boolean.topas",
      "match": "\"(?i:true|false|t|f)\"",
      "captures": {
        "0": { "name": "constant.language.boolean.topas" }
      }
    },

    "string_value": {
      "name": "string.quoted.double.topas",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.language.topas",
          "match": "(?i:true|false)"
        }
      ]
    },

    "unit": {
      "name": "keyword.other.unit.topas",
      "match": "(?<=[\\d\\s])(m|cm|mm|um|nm|km|angstrom|deg|rad|mrad|eV|keV|MeV|GeV|TeV|s|ms|us|ns|ps|g\\/cm3|kg\\/m3|mg\\/cm3|gray|Gy|mGy|pGy|MBq|GBq|kBq|Bq|tesla|gauss)(?=[\\s,#$]|$)",
      "captures": {
        "1": { "name": "keyword.other.unit.topas" }
      }
    },

    "numeric": {
      "name": "constant.numeric.topas",
      "match": "(?<![\\w/])[-+]?(\\d+(\\.\\d*)?|\\.\\d+)([eE][-+]?\\d+)?(?![\\w/])"
    },

    "operator": {
      "name": "keyword.operator.topas",
      "match": "(=|\\s[-+*]\\s)"
    },

    "parameter_ref": {
      "name": "variable.other.reference.topas",
      "match": "(?i:(Ma|El|Is|Ge|Gr|Ph|So|Sc|Tf|Ts|Vr|Rt))[/\\w]+"
    }
  }
}
